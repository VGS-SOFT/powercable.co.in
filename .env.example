# Copy this file to .env.local and fill in your values
# Get all Supabase values from: https://supabase.com/dashboard > Project Settings > API

# -----------------------------------------------
# Supabase — Database for leads storage
# -----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Get service role key from: Supabase Dashboard > Project Settings > API
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# -----------------------------------------------
# Admin Dashboard Password
# Set a strong password for /admin route
# -----------------------------------------------
ADMIN_PASSWORD=your_strong_password_here

# -----------------------------------------------
# Resend — Email delivery for contact form leads
# Get your free API key at: https://resend.com
# Free tier: 3,000 emails/month, 100/day
# -----------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The email address where leads will be delivered
CONTACT_EMAIL=powercable@myyahoo.com

# -----------------------------------------------
# Google Search Console verification
# -----------------------------------------------
NEXT_PUBLIC_GSC_TOKEN=your_gsc_token_here
